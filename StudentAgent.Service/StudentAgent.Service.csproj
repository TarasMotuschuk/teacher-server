<Project Sdk="Microsoft.NET.Sdk.Web">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting.WindowsServices" Version="8.0.1" />
    <PackageReference Include="System.Management" Version="8.0.0" />
    <PackageReference Include="Swashbuckle.AspNetCore" Version="6.6.2" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Teacher.Common\Teacher.Common.csproj" />
  </ItemGroup>
  <ItemGroup>
    <Compile Include="..\StudentAgent.Shared\AgentOptions.cs" Link="Shared\AgentOptions.cs" />
    <Compile Include="..\StudentAgent.Shared\AgentRuntimeSettings.cs" Link="Shared\AgentRuntimeSettings.cs" />
    <Compile Include="..\StudentAgent.Shared\Auth\GlobalExceptionLoggingMiddleware.cs" Link="Shared\Auth\GlobalExceptionLoggingMiddleware.cs" />
    <Compile Include="..\StudentAgent.Shared\Auth\RequestLoggingMiddleware.cs" Link="Shared\Auth\RequestLoggingMiddleware.cs" />
    <Compile Include="..\StudentAgent.Shared\Auth\SharedSecretMiddleware.cs" Link="Shared\Auth\SharedSecretMiddleware.cs" />
    <Compile Include="..\StudentAgent.Shared\Hosting\StudentAgentHostExtensions.cs" Link="Shared\Hosting\StudentAgentHostExtensions.cs" />
    <Compile Include="..\StudentAgent.Shared\Services\AgentDiscoveryService.cs" Link="Shared\Services\AgentDiscoveryService.cs" />
    <Compile Include="..\StudentAgent.Shared\Services\AgentLogService.cs" Link="Shared\Services\AgentLogService.cs" />
    <Compile Include="..\StudentAgent.Shared\Services\AgentSettingsStore.cs" Link="Shared\Services\AgentSettingsStore.cs" />
    <Compile Include="..\StudentAgent.Shared\Services\AgentUpdateService.cs" Link="Shared\Services\AgentUpdateService.cs" />
    <Compile Include="..\StudentAgent.Shared\Services\BrowserLockEnforcementService.cs" Link="Shared\Services\BrowserLockEnforcementService.cs" />
    <Compile Include="..\StudentAgent.Shared\Services\FileService.cs" Link="Shared\Services\FileService.cs" />
    <Compile Include="..\StudentAgent.Shared\Services\NetworkIdentityService.cs" Link="Shared\Services\NetworkIdentityService.cs" />
    <Compile Include="..\StudentAgent.Shared\Services\ProcessService.cs" Link="Shared\Services\ProcessService.cs" />
    <Compile Include="..\StudentAgent.Shared\Services\RegistryService.cs" Link="Shared\Services\RegistryService.cs" />
    <Compile Include="..\StudentAgent.Shared\Services\ServerInfoService.cs" Link="Shared\Services\ServerInfoService.cs" />
    <Compile Include="..\StudentAgent.Shared\Services\StudentAgentPathHelper.cs" Link="Shared\Services\StudentAgentPathHelper.cs" />
    <Compile Include="..\StudentAgent.Shared\UI\Localization\StudentAgentText.cs" Link="Shared\Localization\StudentAgentText.cs" />
  </ItemGroup>
  <ItemGroup>
    <Content Update="appsettings.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
</Project>
