<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:firewall="http://wixtoolset.org/schemas/v4/wxs/firewall"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">
  <Package
      Name="ClassCommander"
      Manufacturer="Taras Motuschuk"
      Version="1.0.5"
      UpgradeCode="9D624377-0AA5-4E8A-970A-5640C752EA0A"
      Scope="perMachine"
      InstallerVersion="500"
      Language="1033">

    <SummaryInformation Description="ClassCommander classroom tools installer." />
    <MajorUpgrade AllowSameVersionUpgrades="yes"
                  DowngradeErrorMessage="A newer version of ClassCommander is already installed." />
    <MediaTemplate EmbedCab="yes" />
    <Icon Id="ClassCommanderProductIcon" SourceFile="..\Branding\ClassCommander-icon.ico" />
    <Property Id="ARPPRODUCTICON" Value="ClassCommanderProductIcon" />

    <!--
      UIHost/VncHost run in the user session (not as children of the service). If they are still
      running, MSI cannot remove the EXEs. Service shutdown now terminates them; these entries are a
      fallback during uninstall/repair (TerminateProcess after timeout).
    -->
    <util:CloseApplication Id="CloseStudentAgentUiHost"
                           Target="StudentAgent.UIHost.exe"
                           RebootPrompt="no"
                           TerminateProcess="1" />
    <util:CloseApplication Id="CloseStudentAgentVncHost"
                           Target="StudentAgent.VncHost.exe"
                           RebootPrompt="no"
                           TerminateProcess="1" />

    <!-- util:CloseApplication schedules its own close-applications actions. -->

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="COMPANYFOLDER" Name="MTD">
        <Directory Id="INSTALLFOLDER" Name="TeacherServer">
        <Directory Id="TEACHERAVALONIADIR" Name="TeacherAvalonia" />
        <Directory Id="STUDENTDIR" Name="Student" />
        </Directory>
      </Directory>
    </StandardDirectory>

    <!--
      ProgramData\TeacherServer\StudentAgent — data directory for the student agent.
      Permissions are set here (install / reinstall / repair) so the agent can write
      its settings and logs even when running as the interactive user via UIHost.
      RemoveFolder removes the directory (and its contents) on uninstall.
    -->
    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="ProgramDataTeacherServer" Name="TeacherServer">
        <Directory Id="ProgramDataStudentAgent" Name="StudentAgent" />
      </Directory>
    </StandardDirectory>

    <Component Id="StudentAgentDataDirComponent" Directory="ProgramDataStudentAgent" Guid="*">
      <CreateFolder>
        <!--
          Grant BUILTIN\Users Modify equivalent rights (Read + Write + Execute + Delete)
          with full inheritance so that both the service (LocalSystem) and the interactive
          UIHost session can create / read / write / delete files and subdirectories.
        -->
        <util:PermissionEx User="Users"
                           GenericRead="yes"
                           GenericWrite="yes"
                           GenericExecute="yes"
                           Delete="yes" />
      </CreateFolder>
      <RemoveFolder Id="RemoveProgramDataStudentAgent" On="uninstall" />
      <RemoveFolder Id="RemoveProgramDataTeacherServer" Directory="ProgramDataTeacherServer" On="uninstall" />
      <RegistryValue Root="HKLM" Key="Software\MTD\TeacherServer" Name="StudentAgentDataDir" Type="integer" Value="1" KeyPath="yes" />
    </Component>

    <!--
      Best-effort cleanup of the Program Files install root on uninstall.
      MSI removes installed files automatically, but any locked EXEs (e.g. UIHost still running)
      or extra artifacts can leave the directory behind. RemoveFolderEx is recursive.
    -->
    <Component Id="InstallFolderCleanupComponent" Directory="INSTALLFOLDER" Guid="*">
      <CreateFolder />
      <util:RemoveFolderEx Property="INSTALLFOLDER" On="uninstall" />
      <RegistryValue Root="HKLM" Key="Software\MTD\TeacherServer" Name="InstallFolderCleanup" Type="integer" Value="1" KeyPath="yes" />
    </Component>

    <!-- Best-effort cleanup of registry keys on uninstall. -->
    <Component Id="TeacherServerRegistryCleanupComponent" Directory="INSTALLFOLDER" Guid="*">
      <RegistryValue Root="HKLM" Key="Software\MTD\TeacherServer" Name="RegistryCleanup" Type="integer" Value="1" KeyPath="yes" />
      <RemoveRegistryKey Root="HKLM" Key="Software\MTD\TeacherServer" Action="removeOnUninstall" />
    </Component>

    <StandardDirectory Id="DesktopFolder" />

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="TeacherProgramMenuFolder" Name="MTD">
        <Directory Id="TeacherProgramMenuAppFolder" Name="TeacherServer" />
      </Directory>
    </StandardDirectory>

    <Feature Id="TeacherFeature" Title="Teacher workstation tools" Description="Install the teacher client (Avalonia)." Level="2" AllowAdvertise="no">
      <ComponentRef Id="TeacherClientAvaloniaMainComponent" />
      <ComponentRef Id="TeacherDesktopShortcutAvaloniaComponent" />
      <ComponentRef Id="TeacherStartMenuShortcutAvaloniaComponent" />
      <ComponentGroupRef Id="TeacherAvaloniaPayloadGroup" />
    </Feature>

    <Feature Id="StudentFeature" Title="Student workstation tools" Description="Install the privileged student service and session UI host." Level="1" AllowAdvertise="no">
      <ComponentRef Id="StudentServiceMainComponent" />
      <ComponentRef Id="StudentUiHostMainComponent" />
      <ComponentRef Id="StudentVncHostMainComponent" />
      <ComponentRef Id="StudentAgentDataDirComponent" />
      <ComponentRef Id="InstallFolderCleanupComponent" />
      <ComponentRef Id="TeacherServerRegistryCleanupComponent" />
      <ComponentGroupRef Id="StudentPayloadGroup" />
    </Feature>

    <Component Id="TeacherClientAvaloniaMainComponent" Directory="TEACHERAVALONIADIR" Guid="*">
      <File Id="TeacherClientAvaloniaExe" Source="$(var.TeacherAvaloniaPayloadDir)\TeacherClient.Avalonia.exe" KeyPath="yes" />
      <firewall:FirewallException Id="TeacherClientAvaloniaFirewallRule"
                                  Name="ClassCommander Teacher Client (Avalonia)"
                                  Description="Allows the Avalonia teacher client to communicate with classroom agents and run live demonstrations."
                                  Program="[#TeacherClientAvaloniaExe]"
                                  Profile="all"
                                  Scope="any" />
    </Component>

    <Component Id="TeacherDesktopShortcutAvaloniaComponent" Directory="DesktopFolder" Guid="*">
      <Shortcut Id="TeacherDesktopShortcutAvalonia"
                Name="ClassCommander"
                Target="[TEACHERAVALONIADIR]TeacherClient.Avalonia.exe"
                WorkingDirectory="TEACHERAVALONIADIR"
                Description="ClassCommander cross-platform teacher client (Avalonia UI)." />
      <RegistryValue Root="HKCU" Key="Software\MTD\TeacherServer" Name="DesktopShortcutAvalonia" Type="integer" Value="1" KeyPath="yes" />
    </Component>

    <Component Id="TeacherStartMenuShortcutAvaloniaComponent" Directory="TeacherProgramMenuAppFolder" Guid="*">
      <Shortcut Id="TeacherStartMenuShortcutAvalonia"
                Name="ClassCommander"
                Target="[TEACHERAVALONIADIR]TeacherClient.Avalonia.exe"
                WorkingDirectory="TEACHERAVALONIADIR"
                Description="ClassCommander cross-platform teacher client (Avalonia UI)." />
      <RemoveFolder Id="RemoveTeacherProgramMenuAppFolder" On="uninstall" />
      <RemoveFolder Id="RemoveTeacherProgramMenuFolder" Directory="TeacherProgramMenuFolder" On="uninstall" />
      <RegistryValue Root="HKCU" Key="Software\MTD\TeacherServer" Name="StartMenuShortcutAvalonia" Type="integer" Value="1" KeyPath="yes" />
    </Component>

    <Component Id="StudentServiceMainComponent" Directory="STUDENTDIR" Guid="*">
      <File Id="StudentAgentServiceExe" Source="$(var.StudentPayloadDir)\StudentAgent.Service.exe" KeyPath="yes" />
      <firewall:FirewallException Id="StudentAgentServiceFirewallRule"
                                  Name="ClassCommander StudentAgent Service"
                                  Description="Allows the StudentAgent service to accept classroom control connections."
                                  Program="[#StudentAgentServiceExe]"
                                  Profile="all"
                                  Scope="any" />
      <ServiceInstall Id="StudentAgentServiceInstaller"
                      Name="StudentAgentService"
                      DisplayName="ClassCommander Student Agent"
                      Description="Privileged StudentAgent runtime host for ClassCommander classroom control."
                      Type="ownProcess"
                      Start="auto"
                      ErrorControl="normal"
                      Account="LocalSystem" />
      <ServiceControl Id="StudentAgentServiceController"
                      Name="StudentAgentService"
                      Start="install"
                      Stop="both"
                      Remove="uninstall"
                      Wait="yes" />
    </Component>

    <Component Id="StudentUiHostMainComponent" Directory="STUDENTDIR" Guid="*">
      <File Id="StudentAgentUiHostExe" Source="$(var.StudentPayloadDir)\StudentAgent.UIHost.exe" KeyPath="yes" />
    </Component>

    <Component Id="StudentVncHostMainComponent" Directory="STUDENTDIR" Guid="*">
      <File Id="StudentAgentVncHostExe" Source="$(var.StudentPayloadDir)\StudentAgent.VncHost.exe" KeyPath="yes" />
      <firewall:FirewallException Id="StudentAgentVncHostFirewallRule"
                                  Name="ClassCommander StudentAgent VNC Host"
                                  Description="Allows the student VNC host to accept remote management connections."
                                  Program="[#StudentAgentVncHostExe]"
                                  Profile="all"
                                  Scope="any" />
    </Component>

    <ui:WixUI Id="WixUI_FeatureTree" />
    <!-- Include standard MSI progress/error text so placeholders like [1], [2] are formatted. -->
    <UIRef Id="WixUI_ErrorProgressText" />
    <WixVariable Id="WixUILicenseRtf" Value="Resources\License.rtf" />
  </Package>
</Wix>
