<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TeacherClient.CrossPlatform.SplashWindow"
        Width="960"
        Height="540"
        MinWidth="960"
        MinHeight="540"
        SystemDecorations="None"
        CanResize="False"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource SplashWindowBackgroundBrush}">
  <Border CornerRadius="14"
          ClipToBounds="True"
          Background="{DynamicResource SplashWindowBackgroundBrush}">
    <Image Source="avares://TeacherClient.Avalonia/Assets/Branding/ClassCommander-splash.png"
           Stretch="UniformToFill" />
  </Border>
</Window>
