<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TeacherClient.CrossPlatform.SplashWindow"
        Width="640"
        Height="320"
        SystemDecorations="None"
        CanResize="False"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A">
  <Grid>
    <Border Width="12" HorizontalAlignment="Left" Background="#3B82F6" />
    <Canvas>
      <Ellipse Width="120" Height="120" Fill="#2563EB" Opacity="0.65" Canvas.Right="72" Canvas.Top="28" />
      <Ellipse Width="60" Height="60" Fill="#2563EB" Opacity="0.65" Canvas.Right="30" Canvas.Top="118" />
    </Canvas>
    <StackPanel Margin="46,82,46,54" Spacing="14" VerticalAlignment="Stretch">
      <TextBlock x:Name="TitleTextBlock"
                 FontSize="28"
                 FontWeight="Bold"
                 Foreground="White"
                 Text="Teacher Classroom Client" />
      <TextBlock x:Name="SubtitleTextBlock"
                 FontSize="12.5"
                 Foreground="#BFDBFE"
                 Text="Preparing the teacher workspace..." />
      <ProgressBar IsIndeterminate="True"
                   Height="14"
                   Margin="0,34,0,0" />
    </StackPanel>
  </Grid>
</Window>
