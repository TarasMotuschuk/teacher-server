<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TeacherClient.CrossPlatform.AboutWindow"
        Width="500"
        Height="310"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Title="About TeacherClient.Avalonia">
  <StackPanel Margin="20" Spacing="14">
    <TextBlock x:Name="TitleTextBlock" FontSize="22" FontWeight="Bold" Text="TeacherClient.Avalonia" />
    <TextBlock x:Name="DescriptionTextBlock" TextWrapping="Wrap"
               Text="TeacherClient.Avalonia is the cross-platform desktop client for connecting to StudentAgent, browsing processes, and performing classroom file operations from macOS, Linux, or Windows." />
    <TextBlock x:Name="VersionTextBlock" FontWeight="SemiBold" Text="Version: 0.0.0" />
    <TextBlock x:Name="CopyrightTextBlock" Text="© 2026 Taras Motuschuk. All rights reserved. Email: mtomekt@gmail.com" />
    <Button x:Name="CloseButton" HorizontalAlignment="Right"
            Width="100"
            Content="Close"
            Click="CloseButton_OnClick" />
  </StackPanel>
</Window>
