<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TeacherClient.CrossPlatform.AboutWindow"
        Width="500"
        Height="310"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Title="About ClassCommander">
  <Grid>
    <Image Source="avares://TeacherClient.Avalonia/Assets/Branding/Backgrounds/teacher-about.png"
           Stretch="UniformToFill" />
    <Border Margin="18"
            Padding="20"
            Background="#D9FFFFFF"
            CornerRadius="12">
      <StackPanel Spacing="14">
        <TextBlock x:Name="TitleTextBlock" FontSize="22" FontWeight="Bold" Foreground="Maroon" Text="ClassCommander" />
        <TextBlock x:Name="DescriptionTextBlock" TextWrapping="Wrap" Foreground="Black"
                   Text="ClassCommander is the cross-platform desktop client for connecting to StudentAgent, browsing processes, and performing classroom file operations from macOS, Linux, or Windows." />
        <TextBlock x:Name="VersionTextBlock" FontWeight="SemiBold" Foreground="Black" Text="Version: 0.0.0" />
        <TextBlock x:Name="CopyrightTextBlock" TextWrapping="Wrap" Foreground="Black" Text="© 2026 Taras Motuschuk. All rights reserved. Email: mtomekt@gmail.com" />
        <Button x:Name="CloseButton" HorizontalAlignment="Right"
                Background="DeepSkyBlue"
                
                Width="100"
                Content="Close"
                Click="CloseButton_OnClick" />
      </StackPanel>
    </Border>
  </Grid>
</Window>
