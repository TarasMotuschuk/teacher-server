<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        x:Class="TeacherClient.CrossPlatform.MainWindow"
        mc:Ignorable="d"
        Width="1320"
        Height="820"
        MinWidth="1100"
        MinHeight="720"
        Background="#2B2B2B"
        Title="ClassCommander">
  <Design.DataContext>
    <x:Null />
  </Design.DataContext>

  <Window.Styles>
    <Style Selector="DataGrid">
      <Setter Property="Background" Value="#F8FAFC" />
      <Setter Property="Foreground" Value="#111827" />
      <Setter Property="BorderBrush" Value="#CBD5E1" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="RowBackground" Value="#FFFFFF" />
      <Setter Property="HorizontalGridLinesBrush" Value="#E2E8F0" />
      <Setter Property="VerticalGridLinesBrush" Value="#E2E8F0" />
      <Setter Property="MinHeight" Value="260" />
    </Style>
    <Style Selector="DataGridCell">
      <Setter Property="Foreground" Value="#111827" />
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="DataGridColumnHeader">
      <Setter Property="Background" Value="#E2E8F0" />
      <Setter Property="Foreground" Value="#0F172A" />
      <Setter Property="BorderBrush" Value="#CBD5E1" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,0,0,0" />
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="ListBoxItem:selected">
      <Setter Property="Background" Value="#3B82F6" />
    </Style>
    <Style Selector="Button.tabAction">
      <Setter Property="Padding" Value="5,2" />
      <Setter Property="MinHeight" Value="30" />
      <Setter Property="MinWidth" Value="126" />
      <Setter Property="MaxWidth" Value="200" />
      <Setter Property="Background" Value="#4A4A4A" />
      <Setter Property="Foreground" Value="#F8FAFC" />
      <Setter Property="BorderBrush" Value="#686868" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.tabAction:pointerover">
      <Setter Property="Background" Value="#5A5A5A" />
      <Setter Property="BorderBrush" Value="#848484" />
    </Style>
    <Style Selector="Button.tabAction:pressed">
      <Setter Property="Background" Value="#414141" />
      <Setter Property="BorderBrush" Value="#979797" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="16">
    <Menu Grid.Row="0" Margin="0,0,0,12">
      <MenuItem x:Name="ConnectionMenuItem" Header="_Connection">
          <MenuItem x:Name="SettingsMenuItem" Header="_Settings" Click="SettingsButton_OnClick" />
          <MenuItem x:Name="RefreshAgentsMenuItem" Header="_Refresh Agents" Click="RefreshAgentsButton_OnClick" />
          <MenuItem x:Name="ConnectSelectedMenuItem" Header="Connect _Selected Agent" Click="ConnectSelectedAgentButton_OnClick" />
          <Separator />
          <MenuItem x:Name="DesktopIconsMenuItem" Header="_Desktop Icons">
            <MenuItem x:Name="SaveDesktopIconLayoutMenuItem" Header="Save desktop icon layout" Click="SaveDesktopIconLayoutMenuItem_OnClick" />
            <MenuItem x:Name="RestoreDesktopIconLayoutMenuItem" Header="Restore desktop icon layout" Click="RestoreDesktopIconLayoutMenuItem_OnClick" />
          </MenuItem>
          <Separator />
          <MenuItem x:Name="AddManualMenuItem" Header="_Add Manual Agent" Click="AddManualAgentButton_OnClick" />
        <MenuItem x:Name="EditManualMenuItem" Header="_Edit Manual Agent" Click="EditManualAgentButton_OnClick" />
        <MenuItem x:Name="RemoveManualMenuItem" Header="_Remove Manual Agent" Click="RemoveManualAgentButton_OnClick" />
      </MenuItem>
      <MenuItem x:Name="GroupCommandsMenuItem" Header="_Group Commands">
        <MenuItem x:Name="DestinationFolderMenuItem" Header="_Destination Folder">
          <MenuItem x:Name="ClearSelectedFolderSelectedMenuItem" Header="Clear destination folder on selected students" Click="ClearSelectedFolderSelectedMenuItem_OnClick" />
          <MenuItem x:Name="ClearSelectedFolderAllMenuItem" Header="Clear destination folder on all online students" Click="ClearSelectedFolderAllMenuItem_OnClick" />
        </MenuItem>
        <MenuItem x:Name="BrowserCommandsMenuItem" Header="_Browser">
          <MenuItem x:Name="LockBrowsersAllMenuItem" Header="Lock browser on all online student PCs" Click="LockBrowsersAllMenuItem_OnClick" />
        </MenuItem>
        <MenuItem x:Name="InputCommandsMenuItem" Header="_Keyboard and Mouse">
          <MenuItem x:Name="LockInputAllMenuItem" Header="Lock keyboard and mouse on all online student PCs" Click="LockInputAllMenuItem_OnClick" />
          <MenuItem x:Name="UnlockInputAllMenuItem" Header="Unlock keyboard and mouse on all online student PCs" Click="UnlockInputAllMenuItem_OnClick" />
        </MenuItem>
        <MenuItem x:Name="CommandsMenuItem" Header="_Commands">
          <MenuItem x:Name="RunCommandSelectedMenuItem" Header="Run command on selected PCs" Click="RunCommandSelectedMenuItem_OnClick" />
          <MenuItem x:Name="RunCommandAllMenuItem" Header="Run command on all online PCs" Click="RunCommandAllMenuItem_OnClick" />
        </MenuItem>
        <MenuItem x:Name="DesktopIconsCommandsMenuItem" Header="_Desktop Icons">
          <MenuItem x:Name="RestoreDesktopIconsSelectedMenuItem" Header="Restore icons on selected PCs" Click="RestoreDesktopIconsSelectedMenuItem_OnClick" />
          <MenuItem x:Name="RestoreDesktopIconsAllMenuItem" Header="Restore icons on all online PCs" Click="RestoreDesktopIconsAllMenuItem_OnClick" />
          <Separator />
          <MenuItem x:Name="ApplyCurrentDesktopIconsSelectedMenuItem" Header="Send current PC layout to selected PCs" Click="ApplyCurrentDesktopIconsSelectedMenuItem_OnClick" />
          <MenuItem x:Name="ApplyCurrentDesktopIconsAllMenuItem" Header="Send current PC layout to all online PCs" Click="ApplyCurrentDesktopIconsAllMenuItem_OnClick" />
        </MenuItem>
        <MenuItem x:Name="PowerCommandsMenuItem" Header="_Power">
          <MenuItem x:Name="SelectedPowerMenuItem" Header="_Selected PCs">
            <MenuItem x:Name="ShutdownSelectedMenuItem" Header="Shut Down" Click="ShutdownSelectedMenuItem_OnClick" />
            <MenuItem x:Name="RestartSelectedMenuItem" Header="Restart" Click="RestartSelectedMenuItem_OnClick" />
            <MenuItem x:Name="LogOffSelectedMenuItem" Header="Log Off" Click="LogOffSelectedMenuItem_OnClick" />
          </MenuItem>
          <MenuItem x:Name="AllOnlinePowerMenuItem" Header="_All Online PCs">
            <MenuItem x:Name="ShutdownAllMenuItem" Header="Shut Down" Click="ShutdownAllMenuItem_OnClick" />
            <MenuItem x:Name="RestartAllMenuItem" Header="Restart" Click="RestartAllMenuItem_OnClick" />
            <MenuItem x:Name="LogOffAllMenuItem" Header="Log Off" Click="LogOffAllMenuItem_OnClick" />
          </MenuItem>
        </MenuItem>
        <MenuItem x:Name="FrequentProgramsMenuItem" Header="_Frequent Programs">
          <MenuItem x:Name="RefreshFrequentProgramsMenuItem" Header="Refresh frequent programs from all PCs" Click="RefreshFrequentProgramsMenuItem_OnClick" />
          <MenuItem x:Name="ManageFrequentProgramsMenuItem" Header="Manage frequent programs" Click="ManageFrequentProgramsMenuItem_OnClick" />
        </MenuItem>
        <Separator />
        <MenuItem x:Name="StudentWorkMenuItem" Header="_Student Work">
          <MenuItem x:Name="CreateStudentWorkFolderAllMenuItem" Header="Create work folder on all PCs" Click="CreateStudentWorkFolderAllMenuItem_OnClick" />
          <MenuItem x:Name="CollectStudentWorkToTeacherPcMenuItem" Header="Collect student work to teacher PC" Click="CollectStudentWorkToTeacherPcMenuItem_OnClick" />
          <MenuItem x:Name="ClearStudentWorkFolderAllMenuItem" Header="Clear work folder on all PCs" Click="ClearStudentWorkFolderAllMenuItem_OnClick" />
        </MenuItem>
      </MenuItem>
      <MenuItem x:Name="HelpMenuItem" Header="_Help">
        <MenuItem x:Name="ProgramUpdatesMenuItem" Header="Program Updates">
          <MenuItem x:Name="CheckAgentUpdateMenuItem" Header="Check Agent Updates" Click="CheckSelectedAgentUpdateMenuItem_OnClick" />
          <MenuItem x:Name="StartAgentUpdateMenuItem" Header="Update Selected PC" Click="StartSelectedAgentUpdateMenuItem_OnClick" />
          <MenuItem x:Name="UpdateSelectedMenuItem" Header="Update selected PCs" Click="UpdateSelectedMenuItem_OnClick" />
          <MenuItem x:Name="UpdateAllMenuItem" Header="Update all online PCs" Click="UpdateAllMenuItem_OnClick" />
          <Separator />
          <MenuItem x:Name="CheckClientUpdateMenuItem" Header="Check for Client Updates" Click="CheckClientUpdateMenuItem_OnClick" />
        </MenuItem>
        <Separator />
        <MenuItem x:Name="AboutMenuItem" Header="_About" Click="AboutMenuItem_OnClick" />
      </MenuItem>
    </Menu>

    <Border Grid.Row="1"
            Padding="12"
            CornerRadius="10"
            Background="#17202A">
      <Grid ColumnDefinitions="Auto,*">
        <Button x:Name="SettingsButton" Grid.Column="0"
                Margin="0,0,14,0"
                Width="120"
                Content="Settings"
                Click="SettingsButton_OnClick" />
        <TextBlock x:Name="StatusTextBlock"
                   Grid.Column="1"
                   VerticalAlignment="Center"
                   TextWrapping="Wrap"
                   Text="Ready. Use the Agents tab to select a student machine, then connect." />
      </Grid>
    </Border>

    <TabControl x:Name="MainTabControl" Grid.Row="2" Margin="0,16,0,16">
      <TabItem x:Name="AgentsTabItem" Header="Agents">
        <Grid RowDefinitions="Auto,Auto,*" Margin="0,12,0,0">
          <WrapPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="RefreshAgentsButton" Classes="tabAction" Width="142" Margin="0,0,5,5" Click="RefreshAgentsButton_OnClick" />
            <Button x:Name="ConnectSelectedAgentButton" Classes="tabAction" Width="176" Margin="0,0,5,5" Click="ConnectSelectedAgentButton_OnClick" />
            <Button x:Name="AddManualAgentButton" Classes="tabAction" Width="148" Margin="0,0,5,5" Click="AddManualAgentButton_OnClick" />
            <Button x:Name="EditManualAgentButton" Classes="tabAction" Width="148" Margin="0,0,5,5" Click="EditManualAgentButton_OnClick" />
            <Button x:Name="RemoveManualAgentButton" Classes="tabAction" Width="172" Margin="0,0,5,5" Click="RemoveManualAgentButton_OnClick" />
          </WrapPanel>

          <Grid Grid.Row="1" ColumnDefinitions="*,240,150,Auto" Margin="0,0,0,12">
            <TextBlock Grid.Column="0"
                       VerticalAlignment="Center"
                       Foreground="#A7ADB4"
                       Text=" " />
            <TextBox x:Name="AgentSearchTextBox"
                     Grid.Column="1"
                     Margin="0,0,12,0"
                     Watermark="Search agents"
                     TextChanged="AgentSearchTextBox_OnTextChanged" />
            <ComboBox x:Name="GroupFilterComboBox"
                      Grid.Column="2"
                      Margin="0,0,12,0"
                      SelectionChanged="AgentFilterComboBox_OnSelectionChanged" />
            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="10">
              <ComboBox x:Name="StatusFilterComboBox" Width="110" SelectionChanged="AgentFilterComboBox_OnSelectionChanged" />
              <CheckBox x:Name="AutoReconnectCheckBox"
                        VerticalAlignment="Center"
                        IsChecked="True"
                        Content="Auto-reconnect" />
            </StackPanel>
          </Grid>

          <DataGrid x:Name="AgentsGrid"
                    Grid.Row="2"
                    AutoGenerateColumns="False"
                    CanUserReorderColumns="False"
                    IsReadOnly="False"
                    SelectionMode="Extended"
                    DoubleTapped="AgentsGrid_OnDoubleTapped">
            <DataGrid.Columns>
              <DataGridTemplateColumn Header="Browser lock" Width="95">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <CheckBox HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              IsChecked="{Binding BrowserLockEnabled}"
                              Tag="{Binding}"
                              Click="BrowserLockCheckBox_OnClick" />
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTemplateColumn Header="Input lock" Width="95">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <CheckBox HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              IsChecked="{Binding InputLockEnabled}"
                              Tag="{Binding}"
                              Click="InputLockCheckBox_OnClick" />
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="120" />
              <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" IsReadOnly="True" />
              <DataGridTextColumn Header="Group" Binding="{Binding GroupName}" Width="150" IsReadOnly="True" />
              <DataGridTextColumn Header="Machine" Binding="{Binding MachineName}" Width="180" IsReadOnly="True" />
              <DataGridTextColumn Header="User" Binding="{Binding CurrentUser}" Width="150" IsReadOnly="True" />
              <DataGridTextColumn Header="IP" Binding="{Binding RespondingAddress}" Width="150" IsReadOnly="True" />
              <DataGridTextColumn Header="Port" Binding="{Binding Port}" Width="90" IsReadOnly="True" />
              <DataGridTextColumn Header="MACs" Binding="{Binding MacAddressesDisplay}" Width="220" IsReadOnly="True" />
              <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="180" IsReadOnly="True" />
              <DataGridTextColumn Header="Update" Binding="{Binding UpdateStatusBadge}" Width="150" IsReadOnly="True" />
              <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="110" IsReadOnly="True" />
              <DataGridTextColumn Header="Last Seen UTC" Binding="{Binding LastSeenDisplay}" Width="190" IsReadOnly="True" />
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </TabItem>

      <TabItem x:Name="ProcessesTabItem" Header="Processes">
        <Grid RowDefinitions="Auto,*" Margin="0,12,0,0">
          <WrapPanel Orientation="Horizontal" Margin="0,0,0,12">
            <Button x:Name="RefreshProcessesButton" Classes="tabAction" Width="138" Margin="0,0,12,10" Click="RefreshProcessesButton_OnClick" />
            <Button x:Name="KillProcessButton" Classes="tabAction" Width="212" Margin="0,0,12,10" Click="KillProcessButton_OnClick" />
          </WrapPanel>

          <DataGrid x:Name="ProcessesGrid"
                    Grid.Row="1"
                    AutoGenerateColumns="False"
                    CanUserReorderColumns="False"
                    IsReadOnly="True"
                    SelectionMode="Single"
                    DoubleTapped="ProcessesGrid_OnDoubleTapped">
            <DataGrid.Columns>
              <DataGridTextColumn Header="PID" Binding="{Binding Id}" Width="90" />
              <DataGridTextColumn Header="Process" Binding="{Binding Name}" Width="220" />
              <DataGridTextColumn Header="Window" Binding="{Binding MainWindowTitle}" Width="3*" />
              <DataGridTextColumn Header="Memory" Binding="{Binding WorkingSetBytes}" Width="140" />
              <DataGridCheckBoxColumn Header="Visible" Binding="{Binding HasVisibleWindow}" Width="100" />
              <DataGridTextColumn Header="Started UTC" Binding="{Binding StartTimeUtc}" Width="220" />
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </TabItem>

      <TabItem x:Name="FilesTabItem" Header="Files">
        <Grid RowDefinitions="Auto,Auto,*" Margin="0,12,0,0">
          <WrapPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="RefreshFilesButton" Classes="tabAction" Width="126" Margin="0,0,5,5" Click="RefreshFilesButton_OnClick" />
            <Button x:Name="UploadButton" Classes="tabAction" Width="110" Margin="0,0,5,5" Click="UploadButton_OnClick" />
            <Button x:Name="DownloadButton" Classes="tabAction" Width="110" Margin="0,0,5,5" Click="DownloadButton_OnClick" />
            <Button x:Name="SendToSelectedStudentsButton" Classes="tabAction" Width="126" Margin="0,0,5,5" Click="SendToSelectedStudentsButton_OnClick" />
            <Button x:Name="SendToAllOnlineStudentsButton" Classes="tabAction" Width="126" Margin="0,0,5,5" Click="SendToAllOnlineStudentsButton_OnClick" />
            <Button x:Name="OpenLocalButton" Classes="tabAction" Width="126" Margin="0,0,5,5" Click="OpenLocalButton_OnClick" />
            <Button x:Name="OpenRemoteButton" Classes="tabAction" Width="126" Margin="0,0,5,5" Click="OpenRemoteButton_OnClick" />
            <Button x:Name="RenameLocalButton" Classes="tabAction" Width="126" Margin="0,0,5,5" Click="RenameLocalButton_OnClick" />
            <Button x:Name="RenameRemoteButton" Classes="tabAction" Width="126" Margin="0,0,5,5" Click="RenameRemoteButton_OnClick" />
            <Button x:Name="NewRemoteFolderButton" Classes="tabAction" Width="126" Margin="0,0,5,5" Click="NewRemoteFolderButton_OnClick" />
            <Button x:Name="DeleteLocalButton" Classes="tabAction" Width="126" Margin="0,0,5,5" Click="DeleteLocalButton_OnClick" />
            <Button x:Name="DeleteRemoteButton" Classes="tabAction" Width="126" Margin="0,0,5,5" Click="DeleteRemoteButton_OnClick" />
          </WrapPanel>

          <Grid Grid.Row="1" ColumnDefinitions="*,*" Margin="0,0,0,12">
            <StackPanel Grid.Column="0" Margin="0,0,8,0" Spacing="8">
              <TextBlock x:Name="TeacherPcTextBlock" FontWeight="Bold" Text="Teacher PC" />
              <Grid ColumnDefinitions="140,88,*,180">
                <ComboBox x:Name="LocalDriveComboBox" Grid.Column="0" Margin="0,0,8,0" SelectionChanged="LocalDriveComboBox_OnSelectionChanged" />
                <Button x:Name="UpLocalButton" Grid.Column="1" Margin="0,0,8,0" Content="Up" Click="UpLocalButton_OnClick" />
                <TextBox x:Name="LocalPathTextBox" Grid.Column="2" IsReadOnly="True" />
                <TextBlock x:Name="LocalDriveSpaceTextBlock" Grid.Column="3" Margin="10,0,0,0" VerticalAlignment="Center" TextAlignment="Right" Foreground="#A7ADB4" Text="Free: unknown" />
              </Grid>
            </StackPanel>

            <StackPanel Grid.Column="1" Spacing="8">
              <TextBlock x:Name="StudentPcTextBlock" FontWeight="Bold" Text="Student PC" />
              <Grid ColumnDefinitions="140,88,*,180">
                <ComboBox x:Name="RemoteDriveComboBox" Grid.Column="0" Margin="0,0,8,0" SelectionChanged="RemoteDriveComboBox_OnSelectionChanged" />
                <Button x:Name="UpRemoteButton" Grid.Column="1" Margin="0,0,8,0" Content="Up" Click="UpRemoteButton_OnClick" />
                <TextBox x:Name="RemotePathTextBox" Grid.Column="2" IsReadOnly="True" />
                <TextBlock x:Name="RemoteDriveSpaceTextBlock" Grid.Column="3" Margin="10,0,0,0" VerticalAlignment="Center" TextAlignment="Right" Foreground="#A7ADB4" Text="Free: unknown" />
              </Grid>
            </StackPanel>
          </Grid>

          <Grid Grid.Row="2" ColumnDefinitions="*,*">
            <DataGrid x:Name="LocalFilesGrid"
                      Grid.Column="0"
                      Margin="0,0,8,0"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      DoubleTapped="LocalFilesGrid_OnDoubleTapped">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding DisplayNameWithIcon}" Width="5.8*" />
                <DataGridTextColumn Header="Extension" Binding="{Binding Extension}" Width="1*" />
                <DataGridTextColumn Header="Attributes" Binding="{Binding AttributesDisplay}" Width="1*" />
                <DataGridTextColumn Header="Size" Binding="{Binding SizeDisplay}" Width="1*" />
                <DataGridTextColumn Header="Modified UTC" Binding="{Binding LastModifiedUtc}" Width="1.2*" />
              </DataGrid.Columns>
            </DataGrid>

            <DataGrid x:Name="RemoteFilesGrid"
                      Grid.Column="1"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      DoubleTapped="RemoteFilesGrid_OnDoubleTapped">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding DisplayNameWithIcon}" Width="5.8*" />
                <DataGridTextColumn Header="Extension" Binding="{Binding Extension}" Width="1*" />
                <DataGridTextColumn Header="Attributes" Binding="{Binding AttributesDisplay}" Width="1*" />
                <DataGridTextColumn Header="Size" Binding="{Binding SizeDisplay}" Width="1*" />
                <DataGridTextColumn Header="Modified UTC" Binding="{Binding LastModifiedUtc}" Width="1.2*" />
              </DataGrid.Columns>
            </DataGrid>
          </Grid>
        </Grid>
      </TabItem>

      <TabItem x:Name="RegistryTabItem" Header="Registry">
        <Grid RowDefinitions="Auto,*" Margin="0,12,0,0">
          <WrapPanel Orientation="Horizontal" Margin="0,0,0,12">
            <Button x:Name="RefreshRegistryButton" Classes="tabAction" Width="138" Margin="0,0,12,10" Click="RefreshRegistryButton_OnClick" />
            <Button x:Name="NewValueButton" Classes="tabAction" Width="144" Margin="0,0,12,10" Click="NewValueButton_OnClick" />
            <Button x:Name="NewKeyButton" Classes="tabAction" Width="132" Margin="0,0,12,10" Click="NewKeyButton_OnClick" />
            <Button x:Name="EditValueButton" Classes="tabAction" Width="138" Margin="0,0,12,10" Click="EditValueButton_OnClick" />
            <Button x:Name="DeleteValueButton" Classes="tabAction" Width="150" Margin="0,0,12,10" Click="DeleteValueButton_OnClick" />
            <Button x:Name="DeleteKeyButton" Classes="tabAction" Width="138" Margin="0,0,12,10" Click="DeleteKeyButton_OnClick" />
            <Button x:Name="ExportRegistryButton" Classes="tabAction" Width="158" Margin="0,0,12,10" Click="ExportRegistryButton_OnClick" />
            <Button x:Name="ImportRegistryButton" Classes="tabAction" Width="158" Margin="0,0,12,10" Click="ImportRegistryButton_OnClick" />
          </WrapPanel>

          <Grid Grid.Row="1" ColumnDefinitions="340,*">
            <TreeView x:Name="RegistryTreeView"
                      Grid.Column="0"
                      Margin="0,0,8,0"
                      Background="#FFFFFF"
                      Foreground="#111827"
                      SelectionChanged="RegistryTreeView_SelectionChanged">
              <TreeView.ItemTemplate>
                <TreeDataTemplate ItemsSource="{Binding Children}">
                  <TextBlock Foreground="#111827" Text="{Binding Name}" />
                </TreeDataTemplate>
              </TreeView.ItemTemplate>
            </TreeView>

            <DataGrid x:Name="RegistryValuesGrid"
                      Grid.Column="1"
                      AutoGenerateColumns="False"
                      CanUserReorderColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*" />
                <DataGridTextColumn Header="Type" Binding="{Binding TypeDisplay}" Width="140" />
                <DataGridTextColumn Header="Data" Binding="{Binding DataDisplay}" Width="4*" />
              </DataGrid.Columns>
            </DataGrid>
          </Grid>
        </Grid>
      </TabItem>

      <TabItem x:Name="RemoteManagementTabItem" Header="Remote management">
        <Grid RowDefinitions="Auto,Auto,*" Margin="0,12,0,0">
          <WrapPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="RefreshRemoteManagementButton" Classes="tabAction" Width="148" Margin="0,0,5,5" Click="RefreshRemoteManagementButton_OnClick" />
            <Button x:Name="StartVncViewOnlyButton" Classes="tabAction" Width="180" Margin="0,0,5,5" Click="StartVncViewOnlyButton_OnClick" />
            <Button x:Name="StartVncControlButton" Classes="tabAction" Width="180" Margin="0,0,5,5" Click="StartVncControlButton_OnClick" />
            <Button x:Name="StopVncButton" Classes="tabAction" Width="132" Margin="0,0,5,5" Click="StopVncButton_OnClick" />
            <Button x:Name="OpenRemoteManagementViewerButton" Classes="tabAction" Width="178" Margin="0,0,5,5" Click="OpenRemoteManagementViewerButton_OnClick" />
          </WrapPanel>

          <TextBlock x:Name="RemoteManagementHintTextBlock"
                     Grid.Row="1"
                     Margin="0,0,0,12"
                     Foreground="#94A3B8"
                     TextWrapping="Wrap"
                     Text="Double-click a tile to open the fullscreen viewer. The buttons above start or stop VNC for the selected PC." />

          <ListBox x:Name="RemoteManagementListBox"
                   Grid.Row="2"
                   SelectionMode="Single"
                   DoubleTapped="RemoteManagementListBox_OnDoubleTapped">
            <ListBox.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel Orientation="Horizontal" />
              </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border Width="238"
                        Height="286"
                        Margin="0,0,12,12"
                        Padding="2"
                        Background="#BFC7D0"
                        BorderBrush="{Binding SelectionBrush}"
                        BorderThickness="3"
                        CornerRadius="8">
                  <Border Background="#171D24" CornerRadius="6" Padding="10">
                    <Grid RowDefinitions="154,32,*">
                      <Border Grid.Row="0" Background="#1A1F26" CornerRadius="4">
                        <Image Source="{Binding PreviewBitmap}"
                               Stretch="UniformToFill"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Stretch" />
                      </Border>
                      <TextBlock Grid.Row="1"
                                 Text="{Binding MachineName}"
                                 FontSize="15"
                                 FontWeight="Bold"
                                 Foreground="White"
                                 TextTrimming="CharacterEllipsis"
                                 VerticalAlignment="Center" />
                      <TextBlock Grid.Row="2"
                                 Margin="0,2,0,0"
                                 Text="{Binding StatusText}"
                                 Foreground="#CBD5E1"
                                 TextWrapping="Wrap" />
                    </Grid>
                  </Border>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>
      </TabItem>
    </TabControl>

    <Border Grid.Row="3"
            Padding="8"
            CornerRadius="10"
            Background="#36404A">
      <TextBlock x:Name="FooterTextBlock" TextWrapping="Wrap"
                 Foreground="#D4D9DF"
                 Text="Avalonia client is cross-platform and now includes the same agent discovery flow as the Windows client, including manual agent groups, status filters, and auto-reconnect against the existing StudentAgent HTTP endpoint." />
    </Border>
  </Grid>
</Window>
