<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        x:Class="TeacherClient.CrossPlatform.MainWindow"
        mc:Ignorable="d"
        Width="1320"
        Height="820"
        MinWidth="1100"
        MinHeight="720"
        Background="#2B2B2B"
        Title="Teacher Classroom Client (Avalonia)">
  <Design.DataContext>
    <x:Null />
  </Design.DataContext>

  <Window.Styles>
    <Style Selector="DataGrid">
      <Setter Property="Background" Value="#F8FAFC" />
      <Setter Property="Foreground" Value="#111827" />
      <Setter Property="BorderBrush" Value="#CBD5E1" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="RowBackground" Value="#FFFFFF" />
      <Setter Property="HorizontalGridLinesBrush" Value="#E2E8F0" />
      <Setter Property="VerticalGridLinesBrush" Value="#E2E8F0" />
      <Setter Property="MinHeight" Value="260" />
    </Style>
    <Style Selector="DataGridCell">
      <Setter Property="Foreground" Value="#111827" />
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="DataGridColumnHeader">
      <Setter Property="Background" Value="#E2E8F0" />
      <Setter Property="Foreground" Value="#0F172A" />
      <Setter Property="BorderBrush" Value="#CBD5E1" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="16">
    <Menu Grid.Row="0" Margin="0,0,0,12">
      <MenuItem Header="_Connection">
        <MenuItem Header="_Connect" Click="ConnectButton_OnClick" />
        <MenuItem Header="_Refresh Agents" Click="RefreshAgentsButton_OnClick" />
        <MenuItem Header="Connect _Selected Agent" Click="ConnectSelectedAgentButton_OnClick" />
        <MenuItem Header="_Add Manual Agent" Click="AddManualAgentButton_OnClick" />
        <MenuItem Header="_Edit Manual Agent" Click="EditManualAgentButton_OnClick" />
        <MenuItem Header="_Remove Manual Agent" Click="RemoveManualAgentButton_OnClick" />
      </MenuItem>
      <MenuItem Header="_Help">
        <MenuItem Header="_About" Click="AboutMenuItem_OnClick" />
      </MenuItem>
    </Menu>

    <Border Grid.Row="1"
            Padding="12"
            CornerRadius="10"
            Background="#17202A">
      <Grid ColumnDefinitions="Auto,250,Auto,200,Auto,*">
        <TextBlock Grid.Column="0" Margin="0,0,10,0" VerticalAlignment="Center" Text="Server URL" />
        <TextBox x:Name="ServerUrlTextBox"
                 Grid.Column="1"
                 Margin="0,0,10,0"
                 Watermark="http://127.0.0.1:5055" />
        <TextBlock Grid.Column="2" Margin="0,0,10,0" VerticalAlignment="Center" Text="Secret" />
        <TextBox x:Name="SharedSecretTextBox"
                 Grid.Column="3"
                 Margin="0,0,10,0" />
        <Button Grid.Column="4"
                Margin="0,0,10,0"
                Width="110"
                Content="Connect"
                Click="ConnectButton_OnClick" />
        <TextBlock x:Name="StatusTextBlock"
                   Grid.Column="5"
                   VerticalAlignment="Center"
                   TextWrapping="Wrap"
                   Text="Ready" />
      </Grid>
    </Border>

    <TabControl Grid.Row="2" Margin="0,16,0,16">
      <TabItem Header="Agents">
        <Grid RowDefinitions="Auto,*" Margin="0,12,0,0">
          <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,160,120,Auto" Margin="0,0,0,12">
            <Button Grid.Column="0" Width="120" Margin="0,0,12,0" Content="Refresh Agents" Click="RefreshAgentsButton_OnClick" />
            <Button Grid.Column="1" Width="140" Margin="0,0,12,0" Content="Connect Selected" Click="ConnectSelectedAgentButton_OnClick" />
            <Button Grid.Column="2" Width="110" Margin="0,0,12,0" Content="Add Manual" Click="AddManualAgentButton_OnClick" />
            <Button Grid.Column="3" Width="110" Margin="0,0,12,0" Content="Edit Manual" Click="EditManualAgentButton_OnClick" />
            <Button Grid.Column="4" Width="130" Margin="0,0,12,0" HorizontalAlignment="Left" Content="Remove Manual" Click="RemoveManualAgentButton_OnClick" />
            <TextBox x:Name="AgentSearchTextBox"
                     Grid.Column="5"
                     Margin="0,0,12,0"
                     Watermark="Search agents"
                     TextChanged="AgentSearchTextBox_OnTextChanged" />
            <ComboBox x:Name="GroupFilterComboBox"
                      Grid.Column="6"
                      Margin="0,0,12,0"
                      SelectionChanged="AgentFilterComboBox_OnSelectionChanged" />
            <StackPanel Grid.Column="7" Orientation="Horizontal" Spacing="10">
              <ComboBox x:Name="StatusFilterComboBox" Width="110" SelectionChanged="AgentFilterComboBox_OnSelectionChanged" />
              <CheckBox x:Name="AutoReconnectCheckBox"
                        VerticalAlignment="Center"
                        IsChecked="True"
                        Content="Auto-reconnect" />
            </StackPanel>
          </Grid>

          <DataGrid x:Name="AgentsGrid"
                    Grid.Row="1"
                    AutoGenerateColumns="False"
                    CanUserReorderColumns="False"
                    IsReadOnly="True"
                    SelectionMode="Single"
                    DoubleTapped="AgentsGrid_OnDoubleTapped">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="120" />
              <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
              <DataGridTextColumn Header="Group" Binding="{Binding GroupName}" Width="150" />
              <DataGridTextColumn Header="Machine" Binding="{Binding MachineName}" Width="180" />
              <DataGridTextColumn Header="User" Binding="{Binding CurrentUser}" Width="150" />
              <DataGridTextColumn Header="IP" Binding="{Binding RespondingAddress}" Width="150" />
              <DataGridTextColumn Header="Port" Binding="{Binding Port}" Width="90" />
              <DataGridTextColumn Header="MACs" Binding="{Binding MacAddressesDisplay}" Width="220" />
              <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="180" />
              <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="110" />
              <DataGridTextColumn Header="Last Seen UTC" Binding="{Binding LastSeenDisplay}" Width="190" />
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </TabItem>

      <TabItem Header="Processes">
        <Grid RowDefinitions="Auto,*" Margin="0,12,0,0">
          <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <Button Width="110" Margin="0,0,10,0" Content="Refresh" Click="RefreshProcessesButton_OnClick" />
            <Button Width="180" Content="Terminate Selected" Click="KillProcessButton_OnClick" />
          </StackPanel>

          <DataGrid x:Name="ProcessesGrid"
                    Grid.Row="1"
                    AutoGenerateColumns="False"
                    CanUserReorderColumns="False"
                    IsReadOnly="True"
                    SelectionMode="Single">
            <DataGrid.Columns>
              <DataGridTextColumn Header="PID" Binding="{Binding Id}" Width="90" />
              <DataGridTextColumn Header="Process" Binding="{Binding Name}" Width="220" />
              <DataGridTextColumn Header="Window" Binding="{Binding MainWindowTitle}" Width="3*" />
              <DataGridTextColumn Header="Memory" Binding="{Binding WorkingSetBytes}" Width="140" />
              <DataGridCheckBoxColumn Header="Visible" Binding="{Binding HasVisibleWindow}" Width="100" />
              <DataGridTextColumn Header="Started UTC" Binding="{Binding StartTimeUtc}" Width="220" />
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </TabItem>

      <TabItem Header="Files">
        <Grid RowDefinitions="Auto,Auto,*" Margin="0,12,0,0">
          <WrapPanel Orientation="Horizontal" ItemHeight="36" ItemWidth="150" Margin="0,0,0,12">
            <Button Margin="0,0,10,10" Content="Refresh Both" Click="RefreshFilesButton_OnClick" />
            <Button Margin="0,0,10,10" Content="Upload -&gt;" Click="UploadButton_OnClick" />
            <Button Margin="0,0,10,10" Content="&lt;- Download" Click="DownloadButton_OnClick" />
            <Button Margin="0,0,10,10" Content="Delete Local" Click="DeleteLocalButton_OnClick" />
            <Button Margin="0,0,10,10" Content="Delete Remote" Click="DeleteRemoteButton_OnClick" />
            <Button Margin="0,0,10,10" Content="New Remote Folder" Click="NewRemoteFolderButton_OnClick" />
          </WrapPanel>

          <Grid Grid.Row="1" ColumnDefinitions="*,*" Margin="0,0,0,12">
            <StackPanel Grid.Column="0" Margin="0,0,8,0" Spacing="8">
              <TextBlock FontWeight="Bold" Text="Teacher PC" />
              <Grid ColumnDefinitions="70,*">
                <Button Grid.Column="0" Margin="0,0,8,0" Content="Up" Click="UpLocalButton_OnClick" />
                <TextBox x:Name="LocalPathTextBox" Grid.Column="1" IsReadOnly="True" />
              </Grid>
            </StackPanel>

            <StackPanel Grid.Column="1" Spacing="8">
              <TextBlock FontWeight="Bold" Text="Student PC" />
              <Grid ColumnDefinitions="70,*">
                <Button Grid.Column="0" Margin="0,0,8,0" Content="Up" Click="UpRemoteButton_OnClick" />
                <TextBox x:Name="RemotePathTextBox" Grid.Column="1" IsReadOnly="True" />
              </Grid>
            </StackPanel>
          </Grid>

          <Grid Grid.Row="2" ColumnDefinitions="*,*">
            <DataGrid x:Name="LocalFilesGrid"
                      Grid.Column="0"
                      Margin="0,0,8,0"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      DoubleTapped="LocalFilesGrid_OnDoubleTapped">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*" />
                <DataGridCheckBoxColumn Header="Dir" Binding="{Binding IsDirectory}" Width="90" />
                <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="120" />
                <DataGridTextColumn Header="Modified UTC" Binding="{Binding LastModifiedUtc}" Width="220" />
              </DataGrid.Columns>
            </DataGrid>

            <DataGrid x:Name="RemoteFilesGrid"
                      Grid.Column="1"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      DoubleTapped="RemoteFilesGrid_OnDoubleTapped">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*" />
                <DataGridCheckBoxColumn Header="Dir" Binding="{Binding IsDirectory}" Width="90" />
                <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="120" />
                <DataGridTextColumn Header="Modified UTC" Binding="{Binding LastModifiedUtc}" Width="220" />
              </DataGrid.Columns>
            </DataGrid>
          </Grid>
        </Grid>
      </TabItem>
    </TabControl>

    <Border Grid.Row="3"
            Padding="12"
            CornerRadius="10"
            Background="#EEF2F6">
      <TextBlock TextWrapping="Wrap"
                 Text="Avalonia client is cross-platform and now includes the same agent discovery flow as the Windows client, including manual agent groups, status filters, and auto-reconnect against the existing StudentAgent HTTP endpoint." />
    </Border>
  </Grid>
</Window>
