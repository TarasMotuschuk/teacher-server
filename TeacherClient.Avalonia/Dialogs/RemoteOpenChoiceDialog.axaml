<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TeacherClient.CrossPlatform.Dialogs.RemoteOpenChoiceDialog"
        Width="480"
        SizeToContent="Height"
        MinHeight="0"
        MaxHeight="900"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Title="Open">
  <Grid RowDefinitions="Auto,Auto,Auto" Margin="16">
    <TextBlock x:Name="DescriptionTextBlock"
               TextWrapping="Wrap"
               Foreground="#94A3B8"
               Margin="0,0,0,10" />
    <StackPanel Grid.Row="1" Spacing="8">
      <RadioButton x:Name="StudentRadio"
                   GroupName="RemoteOpenTarget"
                   Content="Student PC" />
      <RadioButton x:Name="LocalRadio"
                   GroupName="RemoteOpenTarget"
                   Content="This PC (temp)" />
    </StackPanel>
    <StackPanel Grid.Row="2"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="10"
                Margin="0,14,0,0">
      <Button x:Name="CancelButton" Width="100" Click="CancelButton_OnClick" />
      <Button x:Name="OkButton" Width="100" Click="OkButton_OnClick" />
    </StackPanel>
  </Grid>
</Window>
