<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TeacherClient.CrossPlatform.Dialogs.SettingsWindow"
        Width="620"
        Height="500"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Title="ClassCommander Settings">
  <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="200,*" Margin="18">
    <TextBlock x:Name="SharedSecretLabel"
               Grid.Row="0"
               Grid.Column="0"
               Margin="0,8,12,0"
               VerticalAlignment="Top"
               Text="Shared secret" />
    <TextBox x:Name="SharedSecretTextBox"
             Grid.Row="0"
             Grid.Column="1"
             Height="45" />

    <TextBlock x:Name="BulkCopyDestinationPathLabel"
               Grid.Row="1"
               Grid.Column="0"
               Margin="0,8,12,0"
               VerticalAlignment="Top"
               Text="Student destination folder" />
    <TextBox x:Name="BulkCopyDestinationPathTextBox"
             Grid.Row="1"
             Grid.Column="1"
             Height="45" />

    <TextBlock x:Name="StudentWorkRootPathLabel"
               Grid.Row="2"
               Grid.Column="0"
               Margin="0,8,12,0"
               VerticalAlignment="Top"
               Text="Student work base path" />
    <TextBox x:Name="StudentWorkRootPathTextBox"
             Grid.Row="2"
             Grid.Column="1"
             Height="45" />

    <TextBlock x:Name="StudentWorkFolderNameLabel"
               Grid.Row="3"
               Grid.Column="0"
               Margin="0,8,12,0"
               VerticalAlignment="Top"
               Text="Student work folder name" />
    <TextBox x:Name="StudentWorkFolderNameTextBox"
             Grid.Row="3"
             Grid.Column="1"
             Height="45" />

    <TextBlock x:Name="LanguageLabel"
               Grid.Row="4"
               Grid.Column="0"
               Margin="0,8,12,0"
               VerticalAlignment="Top"
               Text="Language" />
    <ComboBox x:Name="LanguageComboBox"
              Grid.Row="4"
              Grid.Column="1"
              Height="45" />

    <TextBlock x:Name="HintTextBlock"
               Grid.Row="5"
               Grid.Column="0"
               Grid.ColumnSpan="2"
               Margin="0,14,0,0"
               TextWrapping="Wrap"
               Text="The shared secret is used for reachability checks and all teacher-to-student API calls. The destination folder defines the starting path on student PCs for bulk file and folder distribution." />

    <StackPanel Grid.Row="6"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="10"
                Margin="0,22,0,0">
      <Button x:Name="CancelButton" Width="100" Content="Cancel" Click="CancelButton_OnClick" />
      <Button x:Name="SaveButton" Width="100" Content="Save" Click="SaveButton_OnClick" />
    </StackPanel>
  </Grid>
</Window>
